# ─────────────────────────────────────────────────────────────
# AI Content Studio — environment variables
#
# The content engine runs entirely locally — NO API KEY REQUIRED.
# These variables are OPTIONAL and only enable cloud persistence.
# Copy this file to `.env.local` if you want to use Supabase.
# ─────────────────────────────────────────────────────────────

# Supabase — https://supabase.com/ (free tier, optional)
# Enables auth + a persistent cloud content library. Without it,
# the library uses in-browser localStorage and works perfectly.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
