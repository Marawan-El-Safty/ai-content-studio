# ─────────────────────────────────────────────────────────────
# AI Content Studio — environment variables
# Copy this file to `.env.local` and fill in your keys.
# The app runs in DEMO MODE if these are left empty (great for
# previewing the UI without any accounts).
# ─────────────────────────────────────────────────────────────

# Anthropic (Claude) — https://console.anthropic.com/
# Enables real AI generation. Without it, the app returns
# realistic mock content so the UI is still fully demoable.
ANTHROPIC_API_KEY=

# Optional: override the model (defaults to a fast, capable model)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase — https://supabase.com/
# Enables auth + persistent content library. Without it, the
# library falls back to in-browser localStorage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
